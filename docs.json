{
  "$schema": "https://mintlify.com/docs.json",
  "name": "new-api 对外文档",
  "theme": "mint",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "openapi": [
    "api/cn/openapi.json",
    "api/en/openapi.json"
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "中文指南",
        "groups": [
          {
            "group": "开始使用",
            "pages": [
              "cn/introduction",
              "cn/quickstart",
              "cn/authentication"
            ]
          }
        ]
      },
      {
        "tab": "API 参考 (CN)",
        "groups": [
          {
            "group": "接口总览",
            "pages": [
              "api-reference/generated/index"
            ]
          },
          {
            "group": "核心接口",
            "pages": [
              "api-reference/generated/openai-chat-/post-/v1/chat/completions",
              "api-reference/generated/claude-messages-/post-/v1/messages",
              "api-reference/generated/gemini-/post-/v1/engines/-model-/embeddings",
              "api-reference/generated/openai-audio-/post-/v1/audio/speech"
            ]
          }
        ]
      },
      {
        "tab": "English Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "en/introduction",
              "en/quickstart",
              "en/authentication"
            ]
          }
        ]
      },
      {
        "tab": "API Reference (EN)",
        "groups": [
          {
            "group": "Endpoints",
            "pages": [
                "api-reference/generated/index"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "API Console",
      "href": "https://your-domain.com"
    }
  },
  "footerSocials": {
    "github": "https://github.com/your-repo"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "vscode"]
