{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OverseasAPI",
  "description": "Overseas API documentation",
  "colors": {
    "primary": "#6d28d9",
    "light": "#f5f3ff",
    "dark": "#2e1065"
  },
  "favicon": {
    "light": "/public/assets/favicon.ico",
    "dark": "/public/assets/favicon.ico"
  },
  "logo": {
    "light": "/public/assets/logo.webp",
    "dark": "/public/assets/logo.webp"
  },
  "navigation": {
    "languages": [
      {
        "language": "cn",
        "tabs": [
          {
            "tab": "API 参考",
            "groups": [
              {
                "group": "概览",
                "pages": [
                  "api-reference/cn/conventions",
                  "api-reference/cn/quickstart",
                  "api-reference/cn/online-debug",
                  "api-reference/cn/ai-codegen"
                ]
              },
              {
                "group": "API",
                "openapi": {
                  "source": "api-reference/cn/openapi.json",
                  "directory": "api-reference/cn"
                }
              }
            ]
          },
          {
            "tab": "开发文档",
            "groups": [
              {
                "group": "快速开始",
                "pages": [
                  "cn/overview",
                  "cn/quickstart",
                  "cn/security"
                ]
              },
              {
                "group": "开发指南",
                "pages": [
                  "cn/base-spec",
                  "cn/error-codes",
                  "cn/models",
                  "cn/multi-format"
                ]
              },
              {
                "group": "使用帮助",
                "pages": [
                  "cn/online-debug",
                  "cn/ai-codegen"
                ]
              },
              {
                "group": "集成与工具",
                "pages": [
                  "cn/tools-cursor",
                  "cn/tools-claude-code",
                  "cn/tools-windsurf",
                  "cn/sdk-python",
                  "cn/sdk-nodejs",
                  "cn/sdk-go"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@aiid.edu.kg"
      },
      {
        "label": "Pricing",
        "href": "https://aiid.edu.kg/pricing"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Console",
      "href": "https://aiid.edu.kg/console"
    }
  },
  "footer": {
    "socials": {
      "telegram": "https://t.me/overseas_api"
    }
  },
  "contextual": {
    "options": [
      "copy"
    ]
  },
  "api": {
    "params": {
      "expanded": "all"
    }
  }
}
