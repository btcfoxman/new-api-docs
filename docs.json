{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "new-api Docs",
  "description": "Unified AI gateway documentation",
  "colors": {
    "primary": "#16A34A",
    "light": "#EFFFF7",
    "dark": "#0B2A1D"
  },
  "favicon": {
    "light": "/public/assets/favicon.ico",
    "dark": "/public/assets/favicon.ico"
  },
  "logo": {
    "light": "/public/assets/logo.png",
    "dark": "/public/assets/logo.png"
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting Started",
                "pages": [
                  "en/overview",
                  "en/quickstart",
                  "en/security"
                ]
              },
              {
                "group": "Developer Guide",
                "pages": [
                  "en/base-spec",
                  "en/error-codes",
                  "en/models",
                  "en/multi-format"
                ]
              },
              {
                "group": "Tools",
                "pages": [
                  "en/tools-cursor",
                  "en/tools-claude-code",
                  "en/tools-windsurf",
                  "en/sdk-python",
                  "en/sdk-nodejs",
                  "en/sdk-go"
                ]
              }
            ]
          },
          {
            "tab": "API Reference",
            "groups": [
              {
                "group": "Overview",
                "pages": [
                  "api/en/sign",
                  "api/en/errors",
                  "api/en/enums",
                  "api/en/webhook"
                ]
              },
              {
                "group": "API",
                "openapi": {
                  "source": "api/en/openapi.json",
                  "directory": "api/en"
                }
              }
            ]
          }
        ]
      },
      {
        "language": "cn",
        "tabs": [
          {
            "tab": "开发文档",
            "groups": [
              {
                "group": "快速开始",
                "pages": [
                  "cn/overview",
                  "cn/quickstart",
                  "cn/security"
                ]
              },
              {
                "group": "开发指南",
                "pages": [
                  "cn/base-spec",
                  "cn/error-codes",
                  "cn/models",
                  "cn/multi-format"
                ]
              },
              {
                "group": "集成与工具",
                "pages": [
                  "cn/tools-cursor",
                  "cn/tools-claude-code",
                  "cn/tools-windsurf",
                  "cn/sdk-python",
                  "cn/sdk-nodejs",
                  "cn/sdk-go"
                ]
              }
            ]
          },
          {
            "tab": "API 参考",
            "groups": [
              {
                "group": "概览",
                "pages": [
                  "api/cn/sign",
                  "api/cn/errors",
                  "api/cn/enums",
                  "api/cn/webhook"
                ]
              },
              {
                "group": "API",
                "openapi": {
                  "source": "api/cn/openapi.json",
                  "directory": "api/cn"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@your-domain.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "API Console",
      "href": "https://your-domain.com"
    }
  }
}
