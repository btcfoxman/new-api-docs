{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "new-api Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "languages": [
      {
        "language": "cn",
        "tabs": [
          {
            "tab": "开发文档",
            "groups": [
              {
                "group": "快速开始",
                "pages": [
                  "docs/cn/introduction",
                  "docs/cn/quickstart",
                  "docs/cn/authentication"
                ]
              },
              {
                "group": "开发指南",
                "pages": [
                  "docs/cn/base-spec",
                  "docs/cn/error-codes",
                  "docs/cn/models",
                  "docs/cn/multi-format"
                ]
              },
              {
                "group": "集成与工具",
                "pages": [
                  "docs/tools/cursor",
                  "docs/tools/claude-code",
                  "docs/tools/windsurf",
                  "docs/tools/sdk-python",
                  "docs/tools/sdk-nodejs",
                  "docs/tools/sdk-go"
                ]
              }
            ]
          },
          {
            "tab": "API 参考",
            "groups": [
              {
                "group": "概览",
                "pages": [
                  "docs/api/cn/sign",
                  "docs/api/cn/errors",
                  "docs/api/cn/enums",
                  "docs/api/cn/webhook"
                ]
              },
              {
                "group": "API",
                "openapi": {
                  "source": "docs/api/cn/openapi.json",
                  "directory": "docs/api/cn"
                }
              }
            ]
          }
        ]
      },
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting Started",
                "pages": [
                  "docs/en/introduction",
                  "docs/en/quickstart",
                  "docs/en/authentication"
                ]
              },
              {
                "group": "Developer Guide",
                "pages": [
                  "docs/en/base-spec",
                  "docs/en/error-codes",
                  "docs/en/models",
                  "docs/en/multi-format"
                ]
              },
              {
                "group": "Tools",
                "pages": [
                  "docs/tools/cursor",
                  "docs/tools/claude-code",
                  "docs/tools/windsurf",
                  "docs/tools/sdk-python",
                  "docs/tools/sdk-nodejs",
                  "docs/tools/sdk-go"
                ]
              }
            ]
          },
          {
            "tab": "API Reference",
            "groups": [
              {
                "group": "Overview",
                "pages": [
                  "docs/api/en/sign",
                  "docs/api/en/errors",
                  "docs/api/en/enums",
                  "docs/api/en/webhook"
                ]
              },
              {
                "group": "API",
                "openapi": {
                  "source": "docs/api/en/openapi.json",
                  "directory": "docs/api/en"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "API Console",
      "href": "https://your-domain.com"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "vscode"]
  }
}
